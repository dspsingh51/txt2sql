APP_NAME=Enterprise AI Text-to-SQL Platform
APP_ENV=local
API_HOST=0.0.0.0
API_PORT=8000
STREAMLIT_SERVER_PORT=8501
SQLITE_DB_PATH=datasets/enterprise_demo.db
